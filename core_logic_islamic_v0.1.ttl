@prefix : <http://philosopher-yar.org/ontology#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

:Core a owl:Ontology .

:Concept a owl:Class .
:Relation a owl:Class .
:Definition a owl:Class .
:Theory a owl:Class .

:LogicOntology a owl:Ontology .
:Proposition a owl:Class .
:Proof a owl:Class .
:EpistemicStatus a owl:Class .
:hasEpistemicStatus a owl:ObjectProperty ;
    rdfs:domain :Proposition ;
    rdfs:range :EpistemicStatus .

:IslamicPhilosophyOntology a owl:Ontology .
:Existence a :Concept ;
    rdfs:label "الوجود"@ar .

:SharedMeaningProposition a :Proposition ;
    rdfs:label "الوجود بمفهومه مشترک معنوی"@ar .
